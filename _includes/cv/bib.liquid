<ul class="card-text font-weight-light list-group list-group-flush">
{% for entry in entries %}
  <li class="list-group-item">
    <div class="row">
      <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
        {% assign entry_year = entry.date | slice: 0, 4 %}
        <table class="table-cv">
          <tbody>
            <tr>
              <td>
                <span class="badge font-weight-bold danger-color-dark text-uppercase align-middle" style="min-width: 75px">{{ entry_year }}</span>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div id="{{ entry.title | slugify }}" class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">

        <!-- Title -->
        <div class="title font-weight-bold">{{ entry.title }}</div>

        <!-- Authors -->
        <div class="author">
          {% assign author_count = entry.authors | size %}
          {% for author_str in entry.authors %}
            {% assign parts = author_str | split: ", " %}
            {% assign author_last = parts[0] %}
            {% assign author_first = parts[1] %}

            {% assign author_is_self = false %}
            {%- assign clean_last = author_last | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
            {%- assign author_last_html = author_last | regex_replace: '([*∗†‡§¶‖&^]+)', '<sup>\1</sup>' -%}
            {% if site.scholar.last_name contains clean_last %}
              {% if site.scholar.first_name contains author_first %}
                {% assign author_is_self = true %}
              {% endif %}
            {% endif %}

            {% assign coauthor_url = null %}
            {%- assign clean_last_lower = clean_last | downcase | remove_accents -%}
            {% if site.data.coauthors[clean_last_lower] %}
              {%- for coauthor in site.data.coauthors[clean_last_lower] -%}
                {% if coauthor.firstname contains author_first %}
                  {%- assign coauthor_url = coauthor.url -%}
                  {% break %}
                {%- endif -%}
              {% endfor %}
            {% endif %}

            {% unless forloop.first %}
              {% if author_count == 2 %}
                {{- " and " -}}
              {% elsif forloop.last %}
                {{- ", and " -}}
              {% else %}
                {{- ", " -}}
              {% endif %}
            {% endunless %}

            {%- if author_is_self -%}
              <em>{{ author_first }} {{ author_last_html }}</em>
            {%- elsif coauthor_url -%}
              <a href="{{ coauthor_url }}">{{ author_first }} {{ author_last_html }}</a>
            {%- else -%}
              {{- author_first }} {{ author_last_html -}}
            {%- endif -%}
          {% endfor %}
        </div>

        <!-- Venue -->
        {% capture entrytype %}
          {% if entry.journal %}
            <em>{{ entry.journal }}</em>
          {% elsif entry.booktitle %}
            <em>In {{ entry.booktitle }}</em>
          {% elsif entry.school %}
            <em>{{ entry.school }}</em>
          {% endif %}
          {% if entry.location %}, {{ entry.location }}{% endif %}
          {% if entry.additional_info %}{{ entry.additional_info | markdownify | remove: '<p>' | remove: '</p>' }}{% endif %}
        {% endcapture %}
        {% assign entrytype_text = entrytype | strip_html | strip %}
        <div class="periodical">
          {{ entrytype | strip }}{% if entrytype_text != "" %}.{% endif %}
        </div>
        <div class="periodical">{{ entry.note | strip }}</div>

        <!-- Links -->
        <div class="links" style="margin-top: 4px;">
          {% if entry.award %}
            <a class="award btn btn-sm z-depth-0" role="button">
              {%- if entry.award_name %}{{ entry.award_name }}{% else %}Awarded{% endif -%}
            </a>
          {% endif %}
          {% if entry.summary %}
  <a class="abstract" role="button" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px; cursor: pointer;">Abs</a>
{% endif %}
          {% if entry.doi %}
            <a href="https://doi.org/{{ entry.doi }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">DOI</a>
          {% endif %}
          {% if entry.url %}
            <a href="{{ entry.url }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">HTML</a>
          {% endif %}
          {% if entry.arxiv %}
            <a href="http://arxiv.org/abs/{{ entry.arxiv }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">arXiv</a>
          {% endif %}
          {% if entry.hal %}
            <a href="https://hal.science/{{ entry.hal }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">HAL</a>
          {% endif %}
          {% if entry.pdf %}
            {% if entry.pdf contains '://' %}
              <a href="{{ entry.pdf }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">PDF</a>
            {% else %}
              <a href="{{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">PDF</a>
            {% endif %}
          {% endif %}
          {% if entry.supp %}
            {% if entry.supp contains '://' %}
              <a href="{{ entry.supp }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Supp</a>
            {% else %}
              <a href="{{ entry.supp | prepend: '/assets/pdf/' | relative_url }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Supp</a>
            {% endif %}
          {% endif %}
          {% if entry.video and site.enable_video_embedding %}
            <a class="abstract" role="button" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px; cursor: pointer;">Video</a>
          {% elsif entry.video %}
            <a href="{{ entry.video }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Video</a>
          {% endif %}
          {% if entry.blog %}
            <a href="{{ entry.blog }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Blog</a>
          {% endif %}
          {% if entry.code %}
            <a href="{{ entry.code }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Code</a>
          {% endif %}
          {% if entry.poster %}
            {% if entry.poster contains '://' %}
              <a href="{{ entry.poster }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Poster</a>
            {% else %}
              <a href="{{ entry.poster | prepend: '/assets/pdf/' | relative_url }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Poster</a>
            {% endif %}
          {% endif %}
          {% if entry.slides %}
            {% if entry.slides contains '://' %}
              <a href="{{ entry.slides }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Slides</a>
            {% else %}
              <a href="{{ entry.slides | prepend: '/assets/pdf/' | relative_url }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Slides</a>
            {% endif %}
          {% endif %}
          {% if entry.website %}
            <a href="{{ entry.website }}" style="font-size: 0.75rem; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); border-radius: 4px; padding: 2px 6px; margin-right: 4px;">Website</a>
          {% endif %}
        </div>

        <!-- Badges -->
        {% if site.enable_publication_badges %}
          {% assign entry_has_altmetric_badge = false %}
          {% if entry.altmetric and entry.altmetric != 'false' %}{% assign entry_has_altmetric_badge = true %}{% endif %}
          {% assign entry_has_dimensions_badge = false %}
          {% if entry.dimensions and entry.dimensions != 'false' %}{% assign entry_has_dimensions_badge = true %}{% endif %}
          {% assign entry_has_google_scholar_badge = false %}
          {% if entry.google_scholar_id %}{% assign entry_has_google_scholar_badge = true %}{% endif %}
          {% assign entry_has_inspirehep_badge = false %}
          {% if entry.inspirehep_id %}{% assign entry_has_inspirehep_badge = true %}{% endif %}

          {% if entry_has_altmetric_badge or entry_has_dimensions_badge or entry_has_google_scholar_badge or entry_has_inspirehep_badge %}
            <div class="badges">
              {% if site.enable_publication_badges.altmetric and entry_has_altmetric_badge %}
                <span class="altmetric-embed" data-badge-type="2" data-badge-popover="right"
                  {% if entry.altmetric != blank and entry.altmetric != 'true' %}data-altmetric-id="{{ entry.altmetric }}"
                  {% elsif entry.arxiv %}data-arxiv-id="{{ entry.arxiv }}"
                  {% elsif entry.doi %}data-doi="{{ entry.doi }}"
                  {% elsif entry.pmid %}data-pmid="{{ entry.pmid }}"
                  {% elsif entry.isbn %}data-isbn="{{ entry.isbn }}"
                  {% endif %}></span>
              {% endif %}
              {% if site.enable_publication_badges.dimensions and entry_has_dimensions_badge %}
                <span class="__dimensions_badge_embed__"
                  {% if entry.dimensions != blank and entry.dimensions != 'true' %}data-id="{{ entry.dimensions }}"
                  {% elsif entry.doi %}data-doi="{{ entry.doi }}"
                  {% else %}data-pmid="{{ entry.pmid }}"
                  {% endif %}
                  data-style="small_rectangle" data-legend="hover-right" style="margin-bottom: 3px;"></span>
              {% endif %}
              {% if site.enable_publication_badges.google_scholar and entry_has_google_scholar_badge %}
                <a href="https://scholar.google.com/citations?view_op=view_citation&hl=en&user={{ site.data.socials.scholar_userid }}&citation_for_view={{ site.data.socials.scholar_userid }}:{{ entry.google_scholar_id }}" aria-label="Google Scholar link" role="button">
                  {% assign citation_count = 0 %}
                  {% assign publication_key = entry.google_scholar_id %}
                  {% if site.data.citations.papers[publication_key] %}
                    {% assign citation_count = site.data.citations.papers[publication_key].citations %}
                  {% else %}
                    {% for paper in site.data.citations.papers %}
                      {% if paper[0] contains entry.google_scholar_id %}
                        {% assign citation_count = paper[1].citations %}
                        {% break %}
                      {% endif %}
                    {% endfor %}
                  {% endif %}
                  <img src="https://img.shields.io/badge/scholar-{{ citation_count }}-4285F4?logo=googlescholar&labelColor=beige" alt="{{ citation_count }} Google Scholar citations">
                </a>
              {% endif %}
              {% if site.enable_publication_badges.inspirehep and entry_has_inspirehep_badge %}
                <a href="https://inspirehep.net/literature/{{ entry.inspirehep_id }}" aria-label="Inspirehep link" role="button">
                  <img src="https://img.shields.io/badge/inspire-{% inspirehep_citations entry.inspirehep_id %}-001628?logo=inspire&logoColor=001628&labelColor=beige" alt="{% inspirehep_citations entry.inspirehep_id %} InspireHEP citations">
                </a>
              {% endif %}
            </div>
          {% endif %}
        {% endif %}

        <!-- Award -->
        {% if entry.award %}
          <div class="award hidden d-print-inline">
            <p>{{ entry.award | markdownify }}</p>
          </div>
        {% endif %}

        <!-- Summary -->
        {% if entry.summary %}
          <div class="abstract hidden">
            <p>{{ entry.summary }}</p>
          </div>
        {% endif %}

        <!-- Video embed -->
        {% if entry.video and site.enable_video_embedding %}
          <div class="abstract hidden">
            <div style="text-align: center;">{% include video.liquid path=entry.video class="img-fluid rounded z-depth-1" controls=true %}</div>
          </div>
        {% endif %}

      </div>
    </div>
  </li>
{% endfor %}
</ul>